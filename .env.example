# OpenClaw Research Framework - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to Git (it's in .gitignore)

# ============================================================================
# FLASK SECURITY (REQUIRED)
# ============================================================================

# Generate strong secret key with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters

# ============================================================================
# API AUTHENTICATION (REQUIRED)
# ============================================================================

# Generate strong API token with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=your-api-token-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (default - good for development)
DATABASE_URL=sqlite:///users.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/openclaw

# MySQL (alternative)
# DATABASE_URL=mysql://username:password@localhost:3306/openclaw

# ============================================================================
# FLASK ENVIRONMENT
# ============================================================================

# Environment: development, testing, production
FLASK_ENV=production

# Debug mode: NEVER set to True in production!
FLASK_DEBUG=False

# Host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ============================================================================
# CELERY (Background Jobs)
# ============================================================================

# Redis (recommended)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Alternative: RabbitMQ
# CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# CELERY_RESULT_BACKEND=rpc://

# ============================================================================
# OWASP ZAP SECURITY SCANNING (Optional)
# ============================================================================

# ZAP API Key (if using security scanning)
ZAP_API_KEY=your-zap-api-key-here
ZAP_HOST=http://localhost:8080

# ============================================================================
# AI SUMMARIZATION (Optional)
# ============================================================================

# Hugging Face model cache directory (optional)
# HF_HOME=/path/to/cache

# Model name (default: facebook/bart-large-cnn)
# SUMMARY_MODEL=facebook/bart-large-cnn

# Device: cpu or cuda
# SUMMARY_DEVICE=cpu

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/openclaw.log

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================

# Enable rate limiting
ENABLE_RATE_LIMITING=True

# Requests per minute
RATE_LIMIT=100

# ============================================================================
# FERNET ENCRYPTION (Job Data)
# ============================================================================

# Generate Fernet key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# ============================================================================
# CORS (If using API from different domains)
# ============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================================================
# NOTES
# ============================================================================

# 1. Generate strong random values for SECRET_KEY, API_TOKEN, FERNET_KEY
# 2. NEVER commit .env file to Git
# 3. Use different secrets for development and production
# 4. Rotate secrets regularly (every 90 days recommended)
# 5. Store production secrets in secure vault (Azure Key Vault, AWS Secrets Manager)

# ============================================================================
# QUICK SETUP COMMANDS
# ============================================================================

# Generate all secrets at once:
# python -c "import secrets; from cryptography.fernet import Fernet; print(f'SECRET_KEY={secrets.token_hex(32)}'); print(f'API_TOKEN={secrets.token_urlsafe(32)}'); print(f'FERNET_KEY={Fernet.generate_key().decode()}')"

# Start Redis (required for Celery):
# redis-server

# Start application:
# python -m web_auth.app

# Start Celery worker:
# celery -A web_auth.celery_worker.celery_app worker --loglevel=info
